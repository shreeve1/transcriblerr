# LLM transcription backend (existing)
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_TRANSCRIPTION_MODEL=whisper-1

# LLM summarization (new)
# API key source at runtime: environment variables only.
# Priority: LLM_SUMMARY_API_KEY, then LLM_API_KEY.
LLM_SUMMARY_ENABLED=true
LLM_SUMMARY_API_BASE_URL=https://api.openai.com/v1
LLM_SUMMARY_MODEL=gpt-4o
LLM_SUMMARY_API_KEY=
LLM_SUMMARY_TIMEOUT_SECS=30
